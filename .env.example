# BookMyShow Movie Ticket Monitor Configuration Template
# Copy this file to '.env' and fill in your actual settings.

# --- Target Movie Settings ---
BMS_MOVIE_ID=ET00480917
# BMS_MOVIE_NAME is optional - movie title is automatically resolved from BMS_MOVIE_ID if omitted
BMS_MOVIE_NAME=the-odyssey
BMS_CITY=chennai
BMS_DATES=20260725,20260726
BMS_INTERVAL=300

# --- Venue Filtering (Optional) ---
# Comma-separated 4-character venue codes (e.g., INPR, PVPZ, RSSC) to restrict alerts to specific theatres
BMS_VENUE_CODES=

# --- Mobile Push Notifications (via ntfy.sh) ---
# Create a unique channel name on ntfy.sh to avoid spam
BMS_NTFY_TOPIC=your-custom-ntfy-topic-here

# --- Email Notifications (SMTP) ---
BMS_EMAIL_SENDER=your-email@gmail.com
BMS_EMAIL_PASSWORD=your-gmail-app-password
BMS_EMAIL_RECIPIENT=destination-email@gmail.com
BMS_EMAIL_SMTP_SERVER=smtp.gmail.com
BMS_EMAIL_SMTP_PORT=587
